// Prisma schema for SQLite
// Run: npx prisma generate && npx prisma migrate dev --name init
// Set DATABASE_URL in .env (defaults to sqlite file)

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  key   String @id
  label String
  // Note: Products still store category as string for compatibility
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  price     Int      // store Ksh as integer (e.g., 4500)
  img       String
  imagesJson String?  // JSON string of image URLs
  meta      String?
  condition String?
  status    String   @default("available")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Slides shown in the hero background carousel
model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  // popupType controls which badge/popup to render e.g. 'flash_sale', 'shop_now', 'price_drop', or 'custom'
  popupType String   @default("flash_sale")
  title     String?  // optional headline for the popup
  subtitle  String?  // optional supporting text
  price     Int?     // price in Ksh to display on the popup
  ctaLabel  String?  // e.g. "Shop Now"
  ctaHref   String?  // link for the CTA button
  productId String?  // optional product to deep-link to /product/[id]
  galleryJson String? // optional additional images for this slide
  sortOrder Int       @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
