# M-Pesa Configuration
# Get these credentials from your M-Pesa Developer Portal
# https://developer.safaricom.co.ke/

# M-Pesa App Credentials (Production)
MPESA_CONSUMER_KEY=your_production_consumer_key_here
MPESA_CONSUMER_SECRET=your_production_consumer_secret_here

# M-Pesa Business Details (Production)
MPESA_BUSINESS_SHORT_CODE=your_production_business_shortcode_here
MPESA_PASSKEY=your_production_passkey_here

# Environment (production for live transactions)
MPESA_ENVIRONMENT=production

# Your production server URL (must be publicly accessible for M-Pesa callbacks)
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Database (Production)
DATABASE_URL="your_production_database_url_here"
